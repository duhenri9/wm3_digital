# Configuração de Produção - WM3 Digital
# Copie este arquivo para .env.local no servidor

# Banco de Dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=wm3_user
DB_PASSWORD=sup@2026UP
DB_PASS=sup@2026UP
DB_NAME=wm3_db

# Segredo JWT (ALTERE EM PRODUÇÃO!)
# Gere uma string aleatória segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# URL da API (opcional, padrão é relativo)
NEXT_PUBLIC_API_URL=

# Ambiente
NODE_ENV=production

# URL do site
NEXT_PUBLIC_SITE_URL=https://wm3digital.com.br

# Caminho do projeto no servidor
PROJECT_PATH=/var/www/wm3

